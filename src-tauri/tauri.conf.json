{
  "productName": "ferrico",
  "version": "0.2.3",
  "identifier": "com.ferrico.app",
  "build": {
    "beforeBuildCommand": "bun run build",
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Ferrico",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: https://tauri.localhost; img-src 'self' tauri: https://tauri.localhost https://icons.duckduckgo.com data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  }
}
