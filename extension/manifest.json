{
  "manifest_version": 3,
  "name": "Ferrico",
  "version": "1.0.0",
  "description": "Save the current page to your Ferrico bookmark library",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Ferrico"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
